{
    "tasks": [
        {
            "type": "cppbuild",         // 任务标签，可以自定义
            "label": "C/C++: g++.exe 生成活动文件",
            "command": "D:\\Compiler\\MinGW\\bin\\g++.exe",         // 编译命令，这里是gcc，我这里用的是MinGW的gcc，确保其在环境变量中能找到
            "args": [
                "-fdiagnostics-color=always",
                "-g",       // 生成调试信息
                "${file}",      // 当前打开的文件
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"    // 输出可执行文件的路径和名称
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ],
    "version": "2.0.0"
}